# MOCO - askmoco.com Environment Variables

# Email service for interest form submissions
# Configure with your preferred email provider (Resend, SendGrid, etc.)
# RESEND_API_KEY=re_xxxxxxxxxxxx

# Optional: store submissions in a database
# DATABASE_URL=postgresql://...

# Site URL (used for OG images, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://askmoco.com
